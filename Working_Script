# ==============================================================================
# 8. PARTICIPANT-LEVEL CORRELATION PLOTS FOR AI SENTENCES
# CLEAN POSTER VERSION WITH EXTREME RT OUTLIER EXCLUSION
# ==============================================================================

# ------------------------------------------------------------------------------
# A. CREATE PARTICIPANT-LEVEL SUMMARY DATAFRAME (AI SENTENCES ONLY)
# ------------------------------------------------------------------------------
df_ai_person <- df_cov %>%
  filter(Sentence_Category == "AI") %>%
  group_by(Participant_Private_ID) %>%
  summarise(
    AI_Familiarity_Score = first(AI_Familiarity_Score),
    AI_Knowledge_Score   = first(AI_Knowledge_Score) * 100,
    mean_ai_rt_ms        = mean(RT_sec, na.rm = TRUE) * 1000,
    ai_error_rate_pct    = mean(Error_Flag, na.rm = TRUE) * 100,
    n_ai_trials          = n(),
    .groups = "drop"
  )

# ------------------------------------------------------------------------------
# B. INSPECT AND EXCLUDE EXTREME PARTICIPANT-LEVEL RT OUTLIERS
# ------------------------------------------------------------------------------

# Extreme outlier rule: values below Q1 - 3*IQR or above Q3 + 3*IQR
rt_q1  <- quantile(df_ai_person$mean_ai_rt_ms, 0.25, na.rm = TRUE)
rt_q3  <- quantile(df_ai_person$mean_ai_rt_ms, 0.75, na.rm = TRUE)
rt_iqr <- IQR(df_ai_person$mean_ai_rt_ms, na.rm = TRUE)

rt_lower_extreme <- rt_q1 - 3 * rt_iqr
rt_upper_extreme <- rt_q3 + 3 * rt_iqr

df_ai_person <- df_ai_person %>%
  mutate(
    extreme_rt_outlier = mean_ai_rt_ms < rt_lower_extreme |
      mean_ai_rt_ms > rt_upper_extreme
  )

cat("\n============================\n")
cat("PARTICIPANT-LEVEL AI RT OUTLIER INSPECTION\n")
cat("============================\n")
cat("Q1:", round(rt_q1, 2), "ms\n")
cat("Q3:", round(rt_q3, 2), "ms\n")
cat("IQR:", round(rt_iqr, 2), "ms\n")
cat("Lower extreme bound:", round(rt_lower_extreme, 2), "ms\n")
cat("Upper extreme bound:", round(rt_upper_extreme, 2), "ms\n")
cat("Number of extreme RT outliers:",
    sum(df_ai_person$extreme_rt_outlier, na.rm = TRUE), "\n")

cat("\nExtreme RT outliers, if any:\n")
print(
  df_ai_person %>%
    filter(extreme_rt_outlier) %>%
    arrange(desc(mean_ai_rt_ms)) %>%
    select(
      Participant_Private_ID,
      mean_ai_rt_ms,
      ai_error_rate_pct,
      AI_Familiarity_Score,
      AI_Knowledge_Score,
      n_ai_trials
    )
)

# Cleaned dataframe used for correlations and plots
df_ai_person_clean <- df_ai_person %>%
  filter(!extreme_rt_outlier)

