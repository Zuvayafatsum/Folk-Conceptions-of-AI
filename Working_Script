    COCA_Zipf
  )

cat("\n============================\n")
cat("COMPLETE-TRIPLET CONCRETENESS SETS\n")
cat("============================\n")
cat("Complete triplets retained:", length(complete_concreteness_sets), "\n")
cat("Target words retained:", nrow(corpus_complete_conc), "\n")
cat("Category counts in retained corpus items:\n")
print(table(corpus_complete_conc$Sentence_Category, useNA = "ifany"))

cat("\nIncomplete or excluded stimulus sets:\n")
print(
  corpus_df %>%
    group_by(Stimulus_Set_ID_num) %>%
    summarise(
      n_rows = n(),
      categories = paste(as.character(Word_Category), collapse = ", "),
      missing_concreteness_words = paste(Target_Word[is.na(Concreteness)], collapse = "; "),
      n_missing_concreteness = sum(is.na(Concreteness)),
      .groups = "drop"
    ) %>%
    filter(!(Stimulus_Set_ID_num %in% complete_concreteness_sets))
)

# ==============================================================================
# 5. JOIN CONCRETENESS TO MAIN BEHAVIORAL DATA
# ==============================================================================

df_conc_complete <- df_cov %>%
  mutate(
    Stem_ID_num = as.integer(Stem_ID_num),
    Sentence_Category = factor(Sentence_Category, levels = c("Human", "AI", "Tool"))
  ) %>%
  inner_join(
    corpus_complete_conc,
    by = c("Stem_ID_num", "Sentence_Category")
  ) %>%
  mutate(
    Stem_ID = factor(Stem_ID_num),
    Sentence_Category = factor(Sentence_Category, levels = c("Human", "AI", "Tool")),
    Participant_Private_ID = factor(Participant_Private_ID),
    Gender = factor(Gender)
  ) %>%
  drop_na(
    RT_sec, Error_Flag, Sentence_Category,
    Age_scaled, Gender, AI_Knowledge_scaled, AI_Familiarity_scaled,
    Concreteness, Concreteness_scaled,
    Participant_Private_ID, Stem_ID
  )

cat("\n============================\n")
cat("CONCRETENESS COMPLETE-TRIPLET BEHAVIORAL DATASET\n")
cat("============================\n")
cat("Rows retained:", nrow(df_conc_complete), "\n")
cat("Participants retained:", n_distinct(df_conc_complete$Participant_Private_ID), "\n")
cat("Stems retained:", n_distinct(df_conc_complete$Stem_ID), "\n")
cat("Target words retained:", n_distinct(paste(df_conc_complete$Stem_ID, df_conc_complete$Sentence_Category)), "\n")
cat("Category counts:\n")
print(table(df_conc_complete$Sentence_Category, useNA = "ifany"))

cat("\nConcreteness descriptives in retained items:\n")
print(
  corpus_complete_conc %>%
    group_by(Sentence_Category) %>%
    summarise(
      n_items = n(),
      mean_concreteness = mean(Concreteness, na.rm = TRUE),
      sd_concreteness = sd(Concreteness, na.rm = TRUE),
      .groups = "drop"
    )
)

# ==============================================================================
# 6. CONCRETENESS-ADJUSTED MODELS
# Same models, now adding item-level concreteness as a fixed-effect covariate.
# ==============================================================================

# ------------------------------------------------------------------------------
# A. RT concreteness-adjusted model
# ------------------------------------------------------------------------------

model_rt_concreteness <- glmer(
  RT_sec ~ Sentence_Category + Concreteness_scaled +
    Age_scaled + Gender + AI_Knowledge_scaled + AI_Familiarity_scaled +
    (1 + Sentence_Category | Participant_Private_ID) +
    (1 | Stem_ID),
  data = df_conc_complete,
  family = Gamma(link = "log"),
  control = glmerControl(optimizer = "bobyqa", optCtrl = list(maxfun = 2e5))
)

cat("\n============================\n")
cat("RT CONCRETENESS-ADJUSTED MODEL\n")
cat("============================\n")
print(summary(model_rt_concreteness))
cat("\nSingular fit?", isSingular(model_rt_concreteness, tol = 1e-4), "\n")



# # # ------------------------------------------------------------------------------
# # # B. Concreteness-adjusted model EMMs
# # # ------------------------------------------------------------------------------
#
emm_rt_concreteness <- emmeans(
  model_rt_concreteness,
  ~ Sentence_Category,
  weights = "proportional"
)



cat("\n============================\n")
cat("RT CONCRETENESS-ADJUSTED: EMMs ON RESPONSE SCALE\n")
cat("============================\n")
print(summary(emm_rt_concreteness, type = "response", infer = c(TRUE, TRUE)))


cat("\n============================\n")
cat("RT CONCRETENESS-ADJUSTED: AI VS TOOL CONTRAST\n")
cat("============================\n")
rt_concreteness_ai_vs_tool <- contrast(
  emm_rt_concreteness,
  method = list("AI vs Tool" = c(0, 1, -1))
)
print(summary(rt_concreteness_ai_vs_tool, type = "response", infer = c(TRUE, TRUE)))

# ==============================================================================
# 10. WALD 95% CIs FOR FIXED EFFECTS
# ==============================================================================

cat("\n============================\n")
cat("RT CONCRETENESS-ADJUSTED: EXPONENTIATED FIXED EFFECTS + 95% WALD CIs\n")
cat("============================\n")
rt_concreteness_ci <- confint(model_rt_concreteness, parm = "beta_", method = "Wald")
print(exp(cbind(Estimate = fixef(model_rt_concreteness), rt_concreteness_ci)))

