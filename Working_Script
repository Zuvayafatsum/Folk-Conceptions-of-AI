# ------------------------------------------------------------------------------
# C. OPTIONAL: RUN PEARSON CORRELATIONS ON CLEANED DATA
# ------------------------------------------------------------------------------

run_cor <- function(data, x, y, label) {
  tmp <- data[, c(x, y)]
  tmp <- tmp[complete.cases(tmp), ]
  
  test <- cor.test(tmp[[x]], tmp[[y]], method = "pearson")
  
  tibble(
    comparison = label,
    n = nrow(tmp),
    r = unname(test$estimate),
    ci_low = test$conf.int[1],
    ci_high = test$conf.int[2],
    p = test$p.value
  )
}

